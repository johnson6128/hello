{
  "name": "hello-todo-worker",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create todo-db",
    "db:migrate": "wrangler d1 execute todo-db --file=./schema.sql",
    "db:migrate:prod": "wrangler d1 execute todo-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.0.0"
  }
}
